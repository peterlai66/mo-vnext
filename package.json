{
	"name": "mo-vnext",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"dev:check": "node scripts/dev-check.js",
		"check:strategy": "npm run dev:check",
		"test": "vitest",
		"cf-typegen": "wrangler types",
		"ac": "git add . && sh -c 'git commit -m \"${1:-chore: 提交變更}\"' --",
		"ship": "sh -c 'if [ -n \"$1\" ]; then npm run ac -- \"$1\"; else npm run ac; fi && git push && npm run deploy' --"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.4",
		"typescript": "^5.5.2",
		"vitest": "~3.2.0",
		"wrangler": "^4.76.0"
	}
}
